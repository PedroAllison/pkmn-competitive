# PostgreSQL (docker-compose.yml da pasta backend sobe um pronto para uso)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pokecompanion

# Redis — OPCIONAL. Sem essa variável (ou com Redis fora do ar) o app sobe
# normalmente e o cache vira no-op (com warning no log).
REDIS_URL=redis://localhost:6379

PORT=3000

# Chave exigida no header `x-api-key` das rotas de sync (POST /sync/run).
ADMIN_API_KEY=change-me

# Baseline de rating dos arquivos de usage do Smogon (0, 1500, 1630, 1695, 1760, 1825).
SMOGON_BASELINE=1760
